# Optional. By default the app writes SQLite data into services/api/data/job_radar.sqlite3
JOB_RADAR_DB=services/api/data/job_radar.sqlite3
JOB_RADAR_ENV=local
JOB_RADAR_PERSONAL_MODE=1
JOB_RADAR_PORT=8000

# WeChat article source switches. START_HERE.command enables both for personal
# local use; set either value to 0 in a local .env file if you want to disable it.
ENABLE_WECHAT_PUBLIC_FETCH=0
ENABLE_WEB_SEARCH_IMPORT=1
ENABLE_SOGOU_DISCOVERY=0
SOGOU_REQUEST_DELAY_SECONDS=2.0
WEB_SEARCH_REQUEST_DELAY_SECONDS=1.0
JOB_RADAR_USER_AGENT=JobRadar/0.6 personal-local-use no-login-cookie contact=operator

# Optional authorized WeChat Official Account API secrets.
# WECHAT_APPSECRET_YOUR_ACCOUNT=replace-me

# Optional external search adapters are not needed for normal personal use.
# Use the in-app Google/Bing/Sogou ordinary search flow instead.
# FIRECRAWL_API_KEY=replace-me
# TAVILY_API_KEY=replace-me
